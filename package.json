{
  "name": "moteur",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build && tsc -b",
    "build:watch": "pnpm -r build && tsc -b --watch",
    "clean": "rimraf dist packages/*/dist",
    "cli": "node dist/src/cli.js",
    "cli:dev": "tsx src/cli.ts",
    "server": "node dist/src/api.js",
    "server:dev": "tsx packages/api/src/index.ts",
    "test": "pnpm -r run test",
    "test:watch": "pnpm -r run test -- --watch",
    "lint": "pnpm -r lint && eslint . --ext .ts",
    "lint:fix": "pnpm -r lint:fix && eslint . --ext .ts"
  },
  "dependencies": {
    "@moteur/api": "workspace:*",
    "@moteur/cli": "workspace:*",
    "@moteur/core": "workspace:*",
    "@moteur/types": "workspace:*",
    "cors": "^2.8.5",
    "openai": "^5.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@flydotio/dockerfile": "^0.7.10",
    "@types/cors": "^2.8.19",
    "@types/node": "^24.0.3",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.35.1",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.1",
    "prettier": "^3.6.0",
    "rimraf": "^5.0.0",
    "supertest": "^7.2.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "form-data": ">=4.0.4",
      "glob": ">=10.5.0",
      "jws": ">=3.2.3",
      "axios": ">=1.13.5",
      "qs": ">=6.14.2",
      "minimatch": ">=9.0.7",
      "rollup": ">=4.59.0",
      "vite": ">=6.4.1",
      "js-yaml": ">=4.1.1",
      "tmp": ">=0.2.4",
      "diff": ">=8.0.3",
      "@eslint/plugin-kit": ">=0.3.4",
      "table>ajv": ">=8.18.0"
    }
  }
}
