{
    "type": "core/gallery",
    "label": "Gallery",
    "description": "A collection of images displayed in a grid or carousel layout.",
    "category": "media",
    "fields": {
        "images": {
            "type": "core/asset-list",
            "label": "Images",
            "required": true
        },
        "caption": {
            "type": "core/text",
            "label": "Caption",
            "multilingual": true
        }
    },
    "optionsSchema": {
        "layout": {
            "type": "core/select",
            "label": "Layout",
            "options": ["grid", "carousel", "masonry"],
            "default": "grid"
        },
        "columns": {
            "type": "core/number",
            "label": "Columns",
            "default": 3
        }
    }
}
